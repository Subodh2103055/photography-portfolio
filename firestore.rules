rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email == "nasirparvez2002@gmail.com" && 
             request.auth.token.email_verified == true;
    }

    function isRecent(time) {
      return time > duration.value(-5, 'm') && time < duration.value(5, 'm');
    }

    match /photo_stats/{photoId} {
      allow read: if true;
      // Only allow increment/decrement of 1, and only if authenticated
      allow write: if isAuthenticated() && 
                   (
                     !exists(/databases/$(database)/documents/photo_stats/$(photoId)) ||
                     (
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount']) &&
                       (request.resource.data.likesCount == resource.data.likesCount + 1 || 
                        request.resource.data.likesCount == resource.data.likesCount - 1)
                     )
                   );
    }

    match /likes/{likeId} {
      allow read: if true;
      // Allow users to manage their own likes
      allow write: if isAuthenticated() && 
                   (likeId == request.auth.uid + '_' + request.resource.data.photoId.replace('/', '___')) &&
                   (likeId.startsWith(request.auth.uid + '_') || isAdmin());
    }

    match /photo_captions/{photoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /photo_overrides/{photoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Allow recursive matches for subcollections just in case
    match /{path=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
