rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email == "nasirparvez2002@gmail.com" && 
             request.auth.token.email_verified == true;
    }

    function isRecent(time) {
      return time > duration.value(-5, 'm') && time < duration.value(5, 'm');
    }

    match /photo_stats/{photoId} {
      allow read: if true;
      allow write: if true; 
    }

    match /likes/{likeId} {
      allow read: if true;
      allow create: if true;
      allow delete: if true;
    }

    match /photo_captions/{photoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /photo_overrides/{photoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /site_comments/{commentId} {
      allow read: if true;
      allow create: if request.resource.data.nickname is string && 
                      request.resource.data.nickname.size() > 0 &&
                      request.resource.data.nickname.size() < 50 &&
                      request.resource.data.text is string &&
                      request.resource.data.text.size() > 0 &&
                      request.resource.data.text.size() < 1000 &&
                      // If it's a reply or marked as admin, it MUST be from the admin
                      ((!('parentId' in request.resource.data) && !('isAdminReply' in request.resource.data)) || isAdmin());
      allow delete: if isAdmin();
    }

    // Allow recursive matches for subcollections just in case
    match /{path=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
